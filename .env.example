# ===========================================
# Tash8eel Operations Platform - Environment
# ===========================================

# Node Environment
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tash8eel
# Worker DB TLS certificate validation. Set to false ONLY for local dev with self-signed certs.
DB_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tash8eel

# ===========================================
# Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
REDIS_DB=0
REDIS_ENABLED=true

# ===========================================
# OpenAI (REQUIRED)
# ===========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_MS=30000
# Force real AI only (true = disable mock fallback paths)
AI_STRICT_MODE=false

# ===========================================
# API Service
# ===========================================
API_PORT=3000
API_HOST=0.0.0.0
API_CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Run SQL migrations automatically during API startup.
RUN_SQL_MIGRATIONS_ON_BOOT=

# Google Places API key for place lookup and address enrichment features.
GOOGLE_PLACES_API_KEY=

# ===========================================
# Portal Service
# ===========================================
PORTAL_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3000
NEXT_PUBLIC_WS_ENABLED=true

# ===========================================
# Worker Service
# ===========================================
WORKER_CONCURRENCY=5
OUTBOX_POLL_INTERVAL_MS=1000
DLQ_MAX_RETRIES=3

# Worker HTTP health endpoint port.
WORKER_HEALTH_PORT=

# ===========================================
# WhatsApp Integration (Meta Cloud API)
# ===========================================
META_ACCESS_TOKEN=your-meta-system-user-token
META_PHONE_NUMBER_ID=your-meta-phone-number-id
META_WABA_ID=your-meta-waba-id
META_APP_SECRET=your-meta-app-secret
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Legacy compatibility (used only by legacy webhook endpoint when enabled)
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ===========================================
# WhatsApp Integration (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_PATH=/v1/webhooks/twilio/whatsapp
TWILIO_STATUS_CALLBACK_PATH=/v1/webhooks/twilio/status
TWILIO_VALIDATE_SIGNATURE=true

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="Tash8eel <no-reply@example.com>"
SMTP_SECURE=false

# ===========================================
# Backups
# ===========================================
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/backups

# ===========================================
# Push Notifications (FCM / APNs)
# ===========================================
# FCM: provide a service account JSON (base64) or a credentials file path
FCM_SERVICE_ACCOUNT=BASE64_JSON
GOOGLE_APPLICATION_CREDENTIALS=

# APNs: Apple token-based auth
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=false

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_PRETTY=true

# ===========================================
# Product Analytics
# ===========================================
ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# ===========================================
# Billing / Subscriptions
# ===========================================
BILLING_PROVIDER=manual
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

# ===========================================
# OpenTelemetry (Tracing/Metrics)
# ===========================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
APP_VERSION=dev

# ===========================================
# Security - CRITICAL: Generate strong secrets!
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-min-32-char-secret-here
JWT_REFRESH_SECRET=generate-another-32-char-secret
API_KEY_SALT=generate-unique-salt-for-hashing

# Admin API Key for internal operations
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=generate-strong-admin-key-64-hex

# Internal API Key for worker -> API calls and trusted internal correlation IDs
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# NextAuth Secret for portal authentication
NEXTAUTH_SECRET=generate-nextauth-secret-32-chars
NEXTAUTH_URL=http://localhost:3001
DOMAIN=yourdomain.com

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ===========================================
# Token & Cost Management
# ===========================================
MAX_CONTEXT_TOKENS=8000
COMPRESSION_THRESHOLD=6000
RECENT_MESSAGES_TO_KEEP=10
DEFAULT_DAILY_TOKEN_BUDGET=100000

# AI routing
# Set to 300 (5 min) — how long to cache merchant plan in Redis
# Lower = more accurate, more DB reads
# Higher = faster, may be stale after plan change
MERCHANT_PLAN_CACHE_TTL_SECONDS=300

# ===========================================
# Transcription (Voice Notes)
# ===========================================
TRANSCRIPTION_MOCK=true

# ===========================================
# Delivery Integration
# ===========================================
DELIVERY_MOCK=true
DELIVERY_API_URL=
DELIVERY_API_KEY=

# ===========================================
# Scheduled Jobs
# ===========================================
DAILY_REPORT_CRON=0 9 * * *
FOLLOWUP_CHECK_CRON=*/5 * * * *
DELIVERY_POLL_CRON=*/2 * * * *
SUBSCRIPTION_GRACE_PERIOD_HOURS=24

# ===========================================
# Feature Flags
# ===========================================
ENABLE_HUMAN_TAKEOVER=true
ENABLE_VOICE_NOTES=true
ENABLE_MEMORY_COMPRESSION=true
ENABLE_CANDIDATE_RETRIEVAL=true
