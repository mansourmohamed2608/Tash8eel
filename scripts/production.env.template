# Tash8eel production environment template
# Copy to /opt/tash8eel/.env and fill all required values.

## DATABASE
# Primary production PostgreSQL connection string (recommended for managed Postgres).
DATABASE_URL=
# Database host (used only when DATABASE_URL is not provided).
DATABASE_HOST=
# Database port (used only when DATABASE_URL is not provided).
DATABASE_PORT=5432
# Database name (used only when DATABASE_URL is not provided).
DATABASE_NAME=
# Database user (used only when DATABASE_URL is not provided).
DATABASE_USER=
# Database password (used only when DATABASE_URL is not provided).
DATABASE_PASSWORD=
# Enable database TLS/SSL connection.
DATABASE_SSL=true
# Validate database TLS certificate chain (must stay true in production).
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Worker-side DB TLS validation flag for certain worker paths.
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional max DB connections override for API/worker internals.
DATABASE_MAX_CONNECTIONS=
# Backup container fallback database host (if running backup sidecar).
BACKUP_DB_HOST=
# Backup container fallback database port (if running backup sidecar).
BACKUP_DB_PORT=5432
# Backup retention period in days for db-backup container.
BACKUP_RETENTION_DAYS=7
# Backup destination directory path used by db-backup container.
BACKUP_DIR=/backups
# Fallback Postgres user for backup sidecar compatibility.
POSTGRES_USER=
# Fallback Postgres password for backup sidecar compatibility.
POSTGRES_PASSWORD=
# Fallback Postgres database name for backup sidecar compatibility.
POSTGRES_DB=

## REDIS
# Enable Redis-backed locks/cache (true in multi-replica production).
REDIS_ENABLED=true
# Full Redis URL (redis:// or rediss://), preferred for managed Redis.
REDIS_URL=
# Redis host fallback when REDIS_URL is empty.
REDIS_HOST=
# Redis port fallback when REDIS_URL is empty.
REDIS_PORT=6379
# Redis password fallback when REDIS_URL is empty.
REDIS_PASSWORD=
# Redis database index fallback when REDIS_URL is empty.
REDIS_DB=0

## AUTH AND SECURITY
# JWT signing secret for access tokens (minimum 32+ random chars).
JWT_SECRET=
# JWT signing secret for refresh tokens (minimum 32+ random chars).
JWT_REFRESH_SECRET=
# Admin API key used by x-admin-api-key protected routes.
ADMIN_API_KEY=
# Internal service-to-service key used by worker -> api calls.
INTERNAL_API_KEY=
# NextAuth secret for portal session/JWT encryption.
NEXTAUTH_SECRET=
# Public NextAuth URL (https://your-domain) for callback/session handling.
NEXTAUTH_URL=
# Allowed CORS origins for API (comma-separated HTTPS origins).
CORS_ORIGINS=
# Default API rate-limit TTL/window in seconds.
RATE_LIMIT_TTL=
# Default API rate-limit max requests.
RATE_LIMIT_MAX=
# Alternative rate-limit window value used by some modules.
RATE_LIMIT_WINDOW=
# Alternative default request limit used by some modules.
RATE_LIMIT_DEFAULT=
# Per-minute max request threshold used by throttling utilities.
RATE_LIMIT_MAX_PER_MINUTE=
# Legacy development webhook secret (do not set in production unless explicitly needed).
DEV_WEBHOOK_SECRET=

## OPENAI
# OpenAI API key for AI responses.
OPENAI_API_KEY=
# Default chat model for response generation.
OPENAI_MODEL=gpt-4o-mini
# Max response tokens for OpenAI calls.
OPENAI_MAX_TOKENS=2048
# Request timeout (ms) for OpenAI calls.
OPENAI_TIMEOUT_MS=30000
# Vision-capable model used for image/vision flows.
OPENAI_VISION_MODEL=
# Strict AI mode (true disables mock/fallback AI behavior).
AI_STRICT_MODE=false
# Candidate retrieval cache TTL for AI retrieval flows.
CANDIDATE_CACHE_TTL=
# Candidate retrieval default item limit for AI retrieval flows.
CANDIDATE_DEFAULT_LIMIT=
# Max context token budget used in prompt assembly.
MAX_CONTEXT_TOKENS=
# Number of recent messages kept in LLM context.
RECENT_MESSAGES_TO_KEEP=
# Merchant plan cache TTL in seconds for AI routing/entitlements.
MERCHANT_PLAN_CACHE_TTL_SECONDS=300
# Toggle mock transcription behavior in speech pipelines.
TRANSCRIPTION_MOCK=

## META WHATSAPP
# Meta WhatsApp Cloud API permanent/system user access token.
META_ACCESS_TOKEN=
# Meta App secret used to validate X-Hub-Signature-256.
META_APP_SECRET=
# Meta WhatsApp phone number ID for outbound message API calls.
META_PHONE_NUMBER_ID=
# Meta WhatsApp Business Account ID (WABA ID).
META_WABA_ID=
# Webhook verification token (must match Meta webhook configuration).
WEBHOOK_VERIFY_TOKEN=
# Legacy/compat WhatsApp verify token used in some older paths.
WHATSAPP_VERIFY_TOKEN=
# Enable legacy webhook path behavior if still required.
LEGACY_WEBHOOK_ENABLED=false
# Legacy Twilio account SID (set only if Twilio legacy channel is active).
TWILIO_ACCOUNT_SID=
# Legacy Twilio auth token (set only if Twilio legacy channel is active).
TWILIO_AUTH_TOKEN=
# Legacy Twilio WhatsApp from number (set only if Twilio channel is active).
TWILIO_WHATSAPP_FROM=
# Legacy Twilio status callback relative path.
TWILIO_STATUS_CALLBACK_PATH=
# Enable Twilio request signature validation in legacy mode.
TWILIO_VALIDATE_SIGNATURE=true

## SMTP EMAIL
# SMTP host used for transactional email.
SMTP_HOST=
# SMTP port (587 for STARTTLS, 465 for SMTPS).
SMTP_PORT=
# SMTP username.
SMTP_USER=
# SMTP password or app password.
SMTP_PASS=
# Default From address for outgoing email.
SMTP_FROM=
# Use secure SMTP transport (true for implicit TLS).
SMTP_SECURE=false

## APP CONFIG
# Application runtime environment.
NODE_ENV=production
# API listen port inside the container.
PORT=3000
# Root domain used by Caddy and URL generation (example: yourdomain.com).
DOMAIN=
# Public application base URL used by some API/notification flows.
APP_URL=
# Public URL fallback used in selected frontend/server helpers.
PUBLIC_URL=
# Optional app version tag for diagnostics/observability.
APP_VERSION=
# Log verbosity level (for example: info, debug, warn, error).
LOG_LEVEL=info
# Pretty-print logs for local/dev readability (keep false in production).
LOG_PRETTY=false
# Portal public base URL used in links sent by API.
PORTAL_BASE_URL=
# Google Places API key for address/place enrichment features.
GOOGLE_PLACES_API_KEY=
# Compression threshold bytes for HTTP response compression.
COMPRESSION_THRESHOLD=
# Run SQL migrations automatically on API boot (true recommended for controlled deployments only).
RUN_SQL_MIGRATIONS_ON_BOOT=true
# Grace period in hours for subscription checks/jobs.
SUBSCRIPTION_GRACE_PERIOD_HOURS=
# Auto-verification tolerance percentage for payment matching.
PAYMENT_AMOUNT_TOLERANCE_PCT=
# Threshold for automatic payment verification logic.
PAYMENT_AUTO_VERIFY_THRESHOLD=
# Container registry prefix used by docker-compose.prod.yml images.
REGISTRY=
# Image tag (usually Git SHA) used by docker-compose.prod.yml.
IMAGE_TAG=
# Toggle OpenTelemetry bootstrap in services.
OTEL_ENABLED=true
# Generic OTLP endpoint used by telemetry exporters.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Explicit OTLP traces endpoint (overrides generic endpoint when set).
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# Explicit OTLP metrics endpoint (overrides generic endpoint when set).
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# APNs team identifier for iOS push notifications.
APNS_TEAM_ID=
# APNs key identifier for iOS push notifications.
APNS_KEY_ID=
# APNs app bundle ID for iOS push notifications.
APNS_BUNDLE_ID=
# APNs private key content (single-line escaped) if not using file path.
APNS_PRIVATE_KEY=
# APNs private key file path on server (alternative to APNS_PRIVATE_KEY).
APNS_PRIVATE_KEY_PATH=
# Use Apple production APNs endpoint (true in production).
APNS_PRODUCTION=true
# Firebase service account JSON content/path for FCM push notifications.
FCM_SERVICE_ACCOUNT=
# Google credentials path for server-side Google SDK integrations.
GOOGLE_APPLICATION_CREDENTIALS=

## WORKER CONFIG
# Worker health endpoint port for container health checks.
WORKER_HEALTH_PORT=3002
# Outbox polling interval in milliseconds.
OUTBOX_POLL_INTERVAL_MS=1000
# Outbox batch size per polling cycle.
OUTBOX_BATCH_SIZE=10
# Orchestrator concurrent job execution limit.
ORCHESTRATOR_CONCURRENCY=5
# Internal base URL for API calls from worker/portal containers.
API_BASE_URL=http://api:3000

## PORTAL CONFIG
# Browser-visible API base URL used by Next.js frontend.
NEXT_PUBLIC_API_URL=
# Browser-visible websocket URL for realtime updates.
NEXT_PUBLIC_WS_URL=
# Toggle realtime websocket features in portal UI.
NEXT_PUBLIC_WS_ENABLED=true
# Toggle frontend analytics instrumentation.
NEXT_PUBLIC_ANALYTICS_ENABLED=false