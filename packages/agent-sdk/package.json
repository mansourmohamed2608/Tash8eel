{
  "name": "@tash8eel/agent-sdk",
  "version": "1.0.0",
  "description": "Shared contracts, schemas, and types for Tash8eel agents",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "require": "./dist/events/index.js",
      "import": "./dist/events/index.js"
    },
    "./tasks": {
      "types": "./dist/tasks/index.d.ts",
      "require": "./dist/tasks/index.js",
      "import": "./dist/tasks/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "require": "./dist/actions/index.js",
      "import": "./dist/actions/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "require": "./dist/entities/index.js",
      "import": "./dist/entities/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
