{
  "info": {
    "_postman_id": "operations-agent-mvp",
    "name": "Operations Agent API",
    "description": "Postman collection for the Operations Agent MVP - a conversational commerce platform with OpenAI GPT-4o-mini.\n\n## Authentication\n- Most endpoints require `x-api-key` header matching merchant API key\n- Admin endpoints require `x-admin-api-key` header\n\n## Environment Variables\n- `base_url`: http://localhost:3000/api\n- `merchant_id`: demo-merchant\n- `api_key`: demo-api-key-12345\n- `admin_key`: super-secret-admin-key",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "merchant_id",
      "value": "demo-merchant"
    },
    {
      "key": "api_key",
      "value": "{{YOUR_MERCHANT_API_KEY}}"
    },
    {
      "key": "admin_key",
      "value": "{{YOUR_ADMIN_API_KEY}}"
    }
  ],
  "item": [
    {
      "name": "A. Inbox - Process Message",
      "item": [
        {
          "name": "Send Text Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchant_id}}\",\n  \"senderId\": \"+201234567890\",\n  \"channel\": \"whatsapp\",\n  \"text\": \"عايز أطلب 2 بيتزا مارجريتا\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/inbox/message",
              "host": ["{{base_url}}"],
              "path": ["v1", "inbox", "message"]
            },
            "description": "Process an incoming customer message. The agent will:\n- Identify intent (order, track, inquiry)\n- Extract items and quantities\n- Collect missing info (address, phone)\n- Apply negotiation rules\n- Respond in Arabic"
          },
          "response": [
            {
              "name": "Order Confirmation",
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"merchantId\": \"demo-merchant\",\n  \"senderId\": \"+201234567890\",\n  \"channel\": \"whatsapp\",\n  \"text\": \"عايز أطلب 2 بيتزا مارجريتا\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/v1/inbox/message"
                }
