# Deployment environment template for /opt/tash8eel/.env
# Fill all values marked REQUIRED before running deployment/deploy.sh.

NODE_ENV=production

# Required image configuration
REGISTRY=ghcr.io/your-org-or-user
IMAGE_TAG=replace-with-commit-sha
APP_VERSION=replace-with-commit-sha

# Required public domains
DOMAIN=example.com
APP_URL=https://api.example.com
PUBLIC_URL=https://example.com
PORTAL_BASE_URL=https://example.com
NEXTAUTH_URL=https://example.com
NEXT_PUBLIC_API_URL=https://api.example.com

# Required secrets
OPENAI_API_KEY=
ADMIN_API_KEY=
JWT_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_API_KEY=
NEXTAUTH_SECRET=

# Required database
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Optional redis
REDIS_ENABLED=false
REDIS_URL=

# Optional WhatsApp Meta
META_ACCESS_TOKEN=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
WEBHOOK_VERIFY_TOKEN=
WHATSAPP_VERIFY_TOKEN=
LEGACY_WEBHOOK_ENABLED=false

# Runtime tuning
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=info
LOG_PRETTY=false
PORT=3000
WORKER_HEALTH_PORT=3002
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=10
ORCHESTRATOR_CONCURRENCY=5
API_BASE_URL=http://api:3000

# CORS
CORS_ORIGINS=https://example.com,https://api.example.com
