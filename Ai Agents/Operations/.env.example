# Environment Configuration
NODE_ENV=development

# Server
PORT=3000
HOST=0.0.0.0

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres_secret_password@localhost:5432/operations_agent
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=operations_agent
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres_secret_password
DATABASE_SSL=false

# Redis (optional but recommended for locks/caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_MS=30000

# Token Budget (default per merchant per day)
DEFAULT_DAILY_TOKEN_BUDGET=100000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin API Key (for admin routes)
ADMIN_API_KEY=admin-secret-key-change-in-production

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Jobs
FOLLOWUP_CHECK_INTERVAL_MS=300000
DAILY_REPORT_CRON=0 9 * * *
OUTBOX_POLL_INTERVAL_MS=5000
DLQ_MAX_RETRIES=5
DLQ_RETRY_DELAY_MS=60000

# Delivery Adapter (mock for now)
DELIVERY_ADAPTER=mock
