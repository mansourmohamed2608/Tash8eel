              "path": ["v1", "conversations", ":conversationId"],
              "query": [
                {
                  "key": "includeMessages",
                  "value": "true"
                }
              ],
              "variable": [
                {
                  "key": "conversationId",
                  "value": "conv-abc123"
                }
              ]
            },
            "description": "Retrieve a conversation by ID, optionally including full message history.\n\nQuery params:\n- includeMessages: true/false (default: false)"
