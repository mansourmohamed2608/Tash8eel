            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchant_id}}\",\n  \"senderId\": \"+201234567890\",\n  \"channel\": \"whatsapp\",\n  \"text\": \"ممكن خصم؟ الطلب كبير\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/inbox/message",
              "host": ["{{base_url}}"],
              "path": ["v1", "inbox", "message"]
            }
