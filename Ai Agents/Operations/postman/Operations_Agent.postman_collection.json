    {
      "name": "C. Catalog - Upsert",
      "item": [
        {
          "name": "Upsert Catalog Items",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"sku\": \"PIZZA-MARG\",\n      \"nameAr\": \"بيتزا مارجريتا\",\n      \"nameEn\": \"Margherita Pizza\",\n      \"price\": 75,\n      \"available\": true,\n      \"category\": \"pizza\"\n    },\n    {\n      \"sku\": \"PIZZA-PEPP\",\n      \"nameAr\": \"بيتزا بيبروني\",\n      \"nameEn\": \"Pepperoni Pizza\",\n      \"price\": 95,\n      \"available\": true,\n      \"category\": \"pizza\"\n    },\n    {\n      \"sku\": \"DRINK-COLA\",\n      \"nameAr\": \"كوكاكولا\",\n      \"nameEn\": \"Coca Cola\",\n      \"price\": 15,\n      \"available\": true,\n      \"category\": \"drinks\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/catalog/upsert",
              "host": ["{{base_url}}"],
              "path": ["v1", "catalog", "upsert"]
            },
            "description": "Bulk upsert catalog items. Uses SKU as unique key.\n\nRequired fields:\n- sku: Unique product identifier\n- nameAr: Arabic product name\n- price: Price in EGP\n\nOptional:\n- nameEn: English name\n- available: true/false\n- category: Product category"
          },
          "response": [
            {
              "name": "Catalog Updated",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"upserted\": 3,\n  \"items\": [\n    { \"sku\": \"PIZZA-MARG\", \"status\": \"updated\" },\n    { \"sku\": \"PIZZA-PEPP\", \"status\": \"created\" },\n    { \"sku\": \"DRINK-COLA\", \"status\": \"updated\" }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Catalog",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/catalog?available=true",
              "host": ["{{base_url}}"],
              "path": ["v1", "catalog"],
              "query": [
                {
                  "key": "available",
                  "value": "true"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
