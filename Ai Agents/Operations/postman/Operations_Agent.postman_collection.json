              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"demo-merchant\",\n  \"name\": \"Demo Restaurant\",\n  \"category\": \"FOOD\",\n  \"config\": {\n    \"brandVoice\": \"ودود ومحترف، نستخدم إيموجي باعتدال\",\n    \"maxDiscount\": 15,\n    \"autoApproveBelow\": 500,\n    \"openingHours\": \"09:00-23:00\"\n  }\n}"
