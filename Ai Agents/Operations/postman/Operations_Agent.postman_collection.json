          "response": [
            {
              "name": "Conversation with Messages",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"conv-abc123\",\n  \"merchantId\": \"demo-merchant\",\n  \"customerId\": \"cust-xyz\",\n  \"channel\": \"whatsapp\",\n  \"state\": \"confirming_order\",\n  \"cart\": [\n    { \"sku\": \"PIZZA-MARG\", \"nameAr\": \"بيتزا مارجريتا\", \"qty\": 2, \"price\": 75 }\n  ],\n  \"messages\": [\n    {\n      \"id\": \"msg-1\",\n      \"role\": \"customer\",\n      \"content\": \"عايز أطلب 2 بيتزا مارجريتا\",\n      \"createdAt\": \"2024-01-15T10:00:00Z\"\n    },\n    {\n      \"id\": \"msg-2\",\n      \"role\": \"assistant\",\n      \"content\": \"أهلاً بيك! إتأكدت من طلبك...\",\n      \"createdAt\": \"2024-01-15T10:00:02Z\"\n    }\n  ]\n}"
