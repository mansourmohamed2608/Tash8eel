            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchant_id}}\",\n  \"senderId\": \"+201234567890\",\n  \"channel\": \"whatsapp\",\n  \"text\": \"تمام، أكد الأوردر\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/inbox/message",
