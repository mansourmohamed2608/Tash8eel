# Environment Configuration
NODE_ENV=development

# Server
PORT=3000
HOST=0.0.0.0

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/operations_agent
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=operations_agent
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME
DATABASE_SSL=false
# Set to false ONLY for local dev with self-signed certs.
# Must be true (default) in staging/production to validate the server certificate.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Worker DB TLS certificate validation. Set to false ONLY for local dev with self-signed certs.
DB_SSL_REJECT_UNAUTHORIZED=true

# Redis
# ----- Local / Docker development -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
# ----- Cloud / Serverless (Upstash, Redis Cloud) -----
# When set, REDIS_URL takes precedence over REDIS_HOST/PORT/PASSWORD.
# For Upstash: use the rediss:// URL from your Upstash console (TLS enabled).
#   REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379
# For Redis Cloud:
#   REDIS_URL=rediss://default:<password>@<host>:<port>
REDIS_URL=
# Set to true to enable Redis. When false, the API falls back to single-instance
# in-memory locking (safe for single-replica deployments only).
REDIS_ENABLED=false

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_MS=30000

# AI routing
# Set to 300 (5 min) — how long to cache merchant plan in Redis
# Lower = more accurate, more DB reads
# Higher = faster, may be stale after plan change
MERCHANT_PLAN_CACHE_TTL_SECONDS=300

META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=
# Force real AI only (true = disable mock fallback paths)
AI_STRICT_MODE=false

# Token Budget (default per merchant per day)
DEFAULT_DAILY_TOKEN_BUDGET=100000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin API Key (for admin routes)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Only used in development. Never set in production.
DEV_WEBHOOK_SECRET=

# Set to true only if legacy webhook integration is active.
LEGACY_WEBHOOK_ENABLED=

# Internal service-to-service API key (used to validate trusted internal callers for x-correlation-id header)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Run SQL migrations automatically during API startup.
RUN_SQL_MIGRATIONS_ON_BOOT=

# Google Places API key for place lookup and address enrichment features.
GOOGLE_PLACES_API_KEY=

# Jobs
FOLLOWUP_CHECK_INTERVAL_MS=300000
DAILY_REPORT_CRON=0 9 * * *
OUTBOX_POLL_INTERVAL_MS=5000
DLQ_MAX_RETRIES=5
DLQ_RETRY_DELAY_MS=60000
SUBSCRIPTION_GRACE_PERIOD_HOURS=24

# Delivery Adapter (mock for now)
DELIVERY_ADAPTER=mock

# Email delivery (SMTP)
# SMTP server hostname
SMTP_HOST=
# SMTP server port (for example: 587)
SMTP_PORT=
# SMTP username
SMTP_USER=
# SMTP password
SMTP_PASS=
# From address used for transactional emails
SMTP_FROM=
# Set to true when the SMTP server requires a secure TLS connection
SMTP_SECURE=

# Merchant portal base URL used in email links
PORTAL_BASE_URL=

# Database backup retention in days.
BACKUP_RETENTION_DAYS=7

# Backup output directory used by the backup container.
BACKUP_DIR=/backups
