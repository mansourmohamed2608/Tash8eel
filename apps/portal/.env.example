# Required portal API base URL
NEXT_PUBLIC_API_URL=
API_BASE_URL=http://api:3000

# Required NextAuth secret
NEXTAUTH_SECRET=
NEXTAUTH_URL=
AUTH_TRUST_HOST=true

# Worker DB TLS certificate validation. Set to false ONLY for local dev with self-signed certs.
DB_SSL_REJECT_UNAUTHORIZED=true

# Grace window before the API deactivates an expired merchant subscription.
SUBSCRIPTION_GRACE_PERIOD_HOURS=24
